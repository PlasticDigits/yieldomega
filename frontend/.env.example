# Copy to `.env` locally if you want non-default values. Only `VITE_*` keys are exposed to the client.

# Optional: Replicate API token for `scripts/replicate-art/*.py` (image generation). Not a `VITE_*` key —
# it is never bundled; `generate_assets.load_env()` reads this file so you can keep one local env.
# REPLICATE_API_TOKEN=r8_…

# Optional: canonical origin for link previews (Open Graph / Twitter). Use https URL with no trailing slash.
# VITE_SITE_URL=https://your-deploy-host.example

# WalletConnect Cloud project ID (public identifier; enables WalletConnect and some mobile wallets).
# Create one at https://cloud.walletconnect.com — not a private API secret, but required for that connector.
VITE_WALLETCONNECT_PROJECT_ID=

# Target chain. Omit or leave unset for local dev defaults (Anvil 31337 + http://127.0.0.1:8545).
# Staging / MegaETH examples: MegaETH testnet 6343 per contracts/deployments/dev-addresses.example.json.
VITE_CHAIN_ID=31337

# Public JSON-RPC URL(s) for that chain (required for contract reads). Use comma-separated URLs to try
# several endpoints in order (no spaces around commas). Same list drives wagmi `fallback` on MegaETH mainnet
# before built-in public fallbacks. Filter support per URL is probed at startup and cached 4h in sessionStorage
# (see docs/frontend/wallet-connection.md#rpc-filter-capability-probe).
VITE_RPC_URL=

# Optional: set to 1 to log each JSON-RPC request and fallback endpoint switches in the browser console.
# VITE_RPC_DEBUG=1

# Indexer HTTP base URL (e.g. http://127.0.0.1:3100) — no credentials in the browser.
VITE_INDEXER_URL=

# Arena v2 contract addresses (0x + 40 hex). Required for play and protocol surfaces (GitLab #266).
VITE_TIME_ARENA_ADDRESS=
VITE_PODIUM_VAULTS_ADDRESS=
VITE_ADMIN_SELL_VAULT_ADDRESS=
VITE_REFERRAL_REGISTRY_ADDRESS=

# Optional: footer link (e.g. CL8Y / Snapshot).
VITE_GOVERNANCE_URL=

# Optional: block explorer base URL — tx links {base}/tx/{hash}, address links {base}/address/{addr}
# (AddressInline, MegaScannerAddressLink, TxHash; default https://mega.etherscan.io). GitLab #98.
VITE_EXPLORER_BASE_URL=

# Optional: display name for the target chain (otherwise "Chain {id}").
VITE_CHAIN_NAME=

# Optional: MegaNames / DotMega registry for reverse display (defaults on MegaETH mainnet chain 4326).
# VITE_DOTMEGA_REGISTRY_ADDRESS=0x5B424C6CCba77b32b9625a6fd5A30D409d20d997

# Optional: third-party DEX frontends (Kumbaya spot / v3, Sir levs) — outbound links only.
# VITE_KUMBAYA_DEX_URL=https://…
# VITE_SIR_DEX_URL=https://…

# Kumbaya v3–compatible routing for DOUB buys via TimeArenaBuyRouter (issue #41, #251).
# Anvil: set automatically by scripts/e2e-anvil.sh.
# MegaETH defaults + runbooks: docs/integrations/kumbaya.md (GitLab issue #46).
# VITE_KUMBAYA_WETH=0x…
# VITE_KUMBAYA_USDM=0x…
# VITE_KUMBAYA_SWAP_ROUTER=0x…
# VITE_KUMBAYA_QUOTER=0x…
# VITE_KUMBAYA_FEE_CL8Y_WETH=3000
# VITE_KUMBAYA_FEE_USDM_WETH=3000

# Playwright Anvil E2E only: enables wagmi `mock` connector (never enable in production CDN builds).
# VITE_E2E_MOCK_WALLET=1

# Optional: Unix seconds timestamp for the public launch. When set and in the future, the entire
# dapp is replaced with a full-screen countdown. After launch, `/` routes to `/arena` (Time Arena).
#
# For local QA of the LaunchCountdown → Arena handoff, prefer the helper env on the stack script:
#   LAUNCH_OFFSET_SEC=90 bash scripts/start-local-anvil-stack.sh SKIP_ANVIL_RICH_STATE=1 START_BOT_SWARM=1
#
# Example value below targets 2026-04-30 17:50:00 UTC.
# VITE_LAUNCH_TIMESTAMP=1777552200
