# Copy to `.env` locally if you want non-default values. Only `VITE_*` keys are exposed to the client.

# Optional: canonical origin for link previews (Open Graph / Twitter). Use https URL with no trailing slash.
# VITE_SITE_URL=https://your-deploy-host.example

# WalletConnect Cloud project ID (public identifier; enables WalletConnect and some mobile wallets).
# Create one at https://cloud.walletconnect.com — not a private API secret, but required for that connector.
VITE_WALLETCONNECT_PROJECT_ID=

# Target chain (e.g. MegaETH testnet 6343 per contracts/deployments/dev-addresses.example.json).
VITE_CHAIN_ID=6343

# Public JSON-RPC URL for that chain (required for contract reads).
VITE_RPC_URL=

# Indexer HTTP base URL (e.g. http://127.0.0.1:3100) — no credentials in the browser.
VITE_INDEXER_URL=

# Deployed contract addresses (0x + 40 hex). Fill after deploy (see dev-addresses JSON).
VITE_TIMECURVE_ADDRESS=
VITE_RABBIT_TREASURY_ADDRESS=
VITE_LEPRECHAUN_NFT_ADDRESS=
VITE_REFERRAL_REGISTRY_ADDRESS=
VITE_FEE_ROUTER_ADDRESS=

# Optional: footer link (e.g. CL8Y / Snapshot).
VITE_GOVERNANCE_URL=

# Optional: block explorer base URL (tx links use {base}/tx/{hash}).
VITE_EXPLORER_BASE_URL=

# Optional: display name for the target chain (otherwise "Chain {id}").
VITE_CHAIN_NAME=

# Optional: MegaNames / DotMega registry for reverse display (defaults on MegaETH mainnet chain 4326).
# VITE_DOTMEGA_REGISTRY_ADDRESS=0x5B424C6CCba77b32b9625a6fd5A30D409d20d997

# Optional: third-party DEX frontends (Kumbaya spot / v3, Sir levs) — outbound links only.
# VITE_KUMBAYA_DEX_URL=https://…
# VITE_SIR_DEX_URL=https://…

# Playwright Anvil E2E only: enables wagmi `mock` connector (never enable in production CDN builds).
# VITE_E2E_MOCK_WALLET=1

# Optional: Unix seconds timestamp for the public launch. When set and in the future, the entire
# dapp is replaced with a full-screen countdown. After the timestamp passes the dapp routes to the
# simple TimeCurve view (`/timecurve`); see docs/frontend/timecurve-views.md.
#
# For local QA of the LaunchCountdown → Simple handoff, prefer the helper env on the stack script:
#   LAUNCH_OFFSET_SEC=90 bash scripts/start-local-anvil-stack.sh SKIP_ANVIL_RICH_STATE=1 START_BOT_SWARM=1
# which appends `VITE_LAUNCH_TIMESTAMP=$((now+90))` to `frontend/.env.local` for you.
#
# Example value below targets 2026-04-30 17:50:00 UTC.
# VITE_LAUNCH_TIMESTAMP=1777552200

