# Copy to `.env` locally if you want non-default values. Only `VITE_*` keys are exposed to the client.

# WalletConnect Cloud project ID (public identifier; enables WalletConnect and some mobile wallets).
# Create one at https://cloud.walletconnect.com — not a private API secret, but required for that connector.
VITE_WALLETCONNECT_PROJECT_ID=

# Default chain id for the wallet session (e.g. 1 Ethereum mainnet, 11155111 Sepolia).
VITE_CHAIN_ID=1

# Optional: override the default RPC URL for the selected chain (public endpoint URLs only).
VITE_RPC_URL=

# Optional: indexer HTTP base URL for reads (no credentials in the browser).
VITE_INDEXER_URL=
