# --- YieldOmega Indexer ---
# Copy to .env and fill in values. Never commit .env with secrets.

# Postgres connection string
DATABASE_URL=postgres://yieldomega:password@localhost:5432/yieldomega_indexer

# MegaETH JSON-RPC endpoint
RPC_URL=https://rpc.megaeth.com

# Chain ID (MegaETH mainnet TBD; use testnet ID during development)
CHAIN_ID=6342

# First block to index (deploy block of earliest contract)
START_BLOCK=0

# HTTP API listen address
LISTEN_ADDR=127.0.0.1:3100
