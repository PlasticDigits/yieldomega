# --- YieldOmega Indexer ---
# Copy to .env and fill in values. Never commit .env with secrets.
# This file is a template only — not production-ready credentials.

# Postgres connection string (use a strong password in real deployments)
DATABASE_URL=postgres://yieldomega:CHANGE_ME_BEFORE_DEPLOY@localhost:5432/yieldomega_indexer

# --- RPC_URL / CHAIN_ID ---
# Defaults below point at public MegaETH-style test infrastructure. They are fine for
# local bring-up smoke tests, but mainnet or private deployments MUST set explicit
# RPC_URL + CHAIN_ID after operator review (wrong chain = wrong index).

# MegaETH JSON-RPC endpoint
RPC_URL=https://rpc.megaeth.com

# Chain ID (must match deployment / registry)
CHAIN_ID=6342

# First block to index: max(START_BLOCK, deployBlock from registry when set)
START_BLOCK=0

# Optional: path to contracts/deployments/dev-addresses.json (filled after deploy)
ADDRESS_REGISTRY_PATH=

# Ingestion loop (set to 0/false to run API-only)
INGESTION_ENABLED=true

# HTTP API listen address
LISTEN_ADDR=127.0.0.1:3100

# Production-only CORS: when INDEXER_PRODUCTION is 1 / true / yes, CORS_ALLOWED_ORIGINS is required
# (comma-separated full origins, e.g. https://rpc.yieldomega.com,https://indexer.yieldomega.com).
# Omit INDEXER_PRODUCTION locally to keep permissive CORS (default).
# With INDEXER_PRODUCTION set, DATABASE_URL must not contain placeholder substrings from .env.example
# (see indexer/README.md, ensure_production_database_url in config.rs).
# INDEXER_PRODUCTION=1
# CORS_ALLOWED_ORIGINS=https://rpc.yieldomega.com,https://indexer.yieldomega.com

# Optional: Postgres URL for `cargo test` integration tests (`tests/integration_stage2.rs`)
# YIELDOMEGA_PG_TEST_URL=postgres://yieldomega:CHANGE_ME_BEFORE_DEPLOY@localhost:5432/yieldomega_indexer_test
