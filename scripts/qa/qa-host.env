# Shared QA host: loopback URLs and fixed ports for SSH -L tunnels from a laptop.
# Loaded by scripts/qa/*.sh after optional repo-root .env (this file wins on duplicate keys).
# Override any value by exporting before `make start-qa` or setting in .env.

export QA_SHARED_HOST="${QA_SHARED_HOST:-1}"

export CHAIN_ID="${CHAIN_ID:-31337}"

export ANVIL_PORT="${ANVIL_PORT:-8545}"
export RPC_URL="${RPC_URL:-http://127.0.0.1:${ANVIL_PORT}}"

export PG_HOST_PORT="${PG_HOST_PORT:-5433}"
export DOCKER_PG="${DOCKER_PG:-yieldomega-pg}"

# Fixed indexer port so `make qa-tunnel-help` matches the running process.
export INDEXER_PORT="${INDEXER_PORT:-3100}"

# Optional: hostname/IP as seen from the laptop (for printed ssh/scp lines).
# export QA_SSH_HOST=qa.example.com
# export QA_SSH_PORT=22
