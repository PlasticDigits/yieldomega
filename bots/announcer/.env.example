# TimeArena buy-announcement bot — environment.
# Fill TELEGRAM_* by hand (nano). Never commit real values.  chmod 600 this file.

# --- Telegram (REQUIRED) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=          # group id, e.g. -1001234567890 (negative)
TELEGRAM_MESSAGE_THREAD_ID=  # forum topic id (e.g. Ω Flow); omit → General

# --- Chain / RPC (MegaETH mainnet defaults; normally leave as-is) ---
MEGAETH_RPC_URL=https://mainnet.megaeth.com/rpc
MEGAETH_RPC_FALLBACKS=https://megaeth.drpc.org,https://rpc-megaeth-mainnet.globalstake.io
CHAIN_ID=4326
TIME_ARENA_ADDRESS=0xba39cea0e5ef6808d8cb926c722877480049e0ee

# --- Explorer links ---
EXPLORER_TX_BASE=https://mega.etherscan.io/tx/
EXPLORER_ADDRESS_BASE=https://mega.etherscan.io/address/

# --- Behavior ---
POLL_INTERVAL_SEC=5
CONFIRMATIONS=2
MAX_BLOCK_SPAN=800
CURSOR_FILE=announce-cursor.json
ANNOUNCE_ARENA_STARTED=1
ANNOUNCE_PODIUM_SETTLED=1
ANNOUNCE_PODIUM_COUNTDOWN=1
# PODIUM_COUNTDOWN_THRESHOLDS_SEC=600,300,60,30,10
TELEGRAM_MIN_INTERVAL_SEC=3.5      # throttle (~<20 msgs/min group cap)
# ANNOUNCE_START_BLOCK=            # optional: first run starts here; else current head
# MIN_DOUB=0                       # skip buys under this DOUB amount

# --- Indexer (USD / prize pool) ---
INDEXER_URL=https://indexer.yieldomega.com
INDEXER_CACHE_SEC=30
# DOUB_USD_FALLBACK=0.98           # when doub-spot-price is unavailable (503 / not deployed yet)

# --- First-test toggles (comment out for production) ---
# DRY_RUN=1                        # log instead of send (no token needed)
# STARTUP_PING=1                   # post "watcher online" on start
# SEND_TEST_ON_START=1             # post one sample buy on start (verify formatting)
