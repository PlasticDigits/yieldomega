# Copy to `.env` or `.env.local` (gitignored). Never commit real keys.
# -----------------------------------------------------------------------------
# Required for RPC reads (inspect and dry-run strategies)
# -----------------------------------------------------------------------------
# HTTP JSON-RPC (Anvil or public endpoint)
YIELDOMEGA_RPC_URL=http://127.0.0.1:8545
# Alternate name supported:
# RPC_URL=http://127.0.0.1:8545

# Must match the chain your RPC serves (Anvil default: 31337)
YIELDOMEGA_CHAIN_ID=31337

# TimeCurve proxy/implementation address (checksummed hex)
YIELDOMEGA_TIMECURVE_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Optional addresses (recommended for local dev parity with frontend VITE_*)
# -----------------------------------------------------------------------------
YIELDOMEGA_RABBIT_TREASURY_ADDRESS=
YIELDOMEGA_LEPRECHAUN_NFT_ADDRESS=
# If unset, `acceptedAsset` is read from the TimeCurve contract on each run.
YIELDOMEGA_ACCEPTED_ASSET_ADDRESS=

# JSON file like contracts/deployments/stage2-anvil-registry.json — fills missing fields
YIELDOMEGA_ADDRESS_FILE=

# -----------------------------------------------------------------------------
# Transaction signing (only with explicit send — see README)
# -----------------------------------------------------------------------------
# Hex private key without 0x prefix is fine; local Anvil account #0 test key is for dev only.
YIELDOMEGA_PRIVATE_KEY=

# Default is dry-run: no txs unless you pass CLI `--send` OR set both below.
# YIELDOMEGA_DRY_RUN=1
# YIELDOMEGA_SEND_TX=1

# One-shot Anvil dev funding: anvil_setBalance + mock reserve mint (swarm only; chain 31337). Default off — never on mainnet.
# YIELDOMEGA_ALLOW_ANVIL_FUNDING=1

# Comma- or whitespace-separated checksummed 0x addresses (no private keys). Included in the same one-shot funding as swarm bots — Anvil 31337 + allow-anvil-funding only.
# YIELDOMEGA_ANVIL_EXTRA_FUNDED_ADDRESSES=0xYourQaWalletAddressHere

# -----------------------------------------------------------------------------
# Tunables
# -----------------------------------------------------------------------------
YIELDOMEGA_POLL_INTERVAL_SEC=30
YIELDOMEGA_GAS_MULTIPLIER=1.1
# Extra wei added on top of eth_estimateGas (avoids tight limits on heavy txs, e.g. mock mint).
# YIELDOMEGA_GAS_BUFFER=100000
# Fixed CHARM wad for fun/shark (0 = use onchain min/max at runtime)
YIELDOMEGA_CHARM_WAD_FUN=0
YIELDOMEGA_CHARM_WAD_SHARK=0

# Second wallet for `pvp` victim (defaults to well-known Anvil key #1 if unset — LOCAL ONLY)
YIELDOMEGA_PVP_VICTIM_PRIVATE_KEY=
