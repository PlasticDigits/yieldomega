#!/bin/sh
# Gitleaks on staged changes; TypeScript check when paths under frontend/ are staged.
# Install hooks: git config core.hooksPath .githooks
set -eu

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks: not found in PATH. Install from https://github.com/gitleaks/gitleaks/releases" >&2
  echo "  Example: brew install gitleaks   or   download a release binary" >&2
  exit 1
fi

gitleaks protect --staged --verbose --config .gitleaks.toml

if git diff --cached --name-only | grep -qE '^frontend/'; then
  if ! command -v npm >/dev/null 2>&1; then
    echo "npm: not found in PATH (required for frontend typecheck)" >&2
    exit 1
  fi
  if [ ! -f frontend/node_modules/.bin/tsc ]; then
    echo "frontend typecheck: no local tsc (install deps first). Run: cd frontend && npm ci" >&2
    exit 1
  fi
  (cd frontend && npm run typecheck)
fi
